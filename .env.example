# Divini Partners — self-hosted Supabase (anon key is safe to expose in client code; RLS protects data)
# Point these at your OWN Supabase stack, not the hosted SaaS project.
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=replace-with-self-hosted-anon-jwt
# Server-only secret (NEVER commit). Used by self-hosted stack / admin scripts:
# SUPABASE_SERVICE_ROLE_KEY=...
