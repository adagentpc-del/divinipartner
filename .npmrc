# Use a flat, hoisted node_modules (npm-style) instead of pnpm's default
# isolated layout. The server TypeScript build relies on tsc's automatic
# discovery of @types/node under node_modules/@types; pnpm's isolated store
# hides it, so the server build failed with "Cannot find name 'process' /
# 'console'". Hoisting mirrors the DigitalOcean droplet (which builds with npm)
# and fixes the type resolution for both the root and server installs.
node-linker=hoisted
shamefully-hoist=true
# Ensure devDependencies (vite, typescript, @types/*) install even if the host
# sets NODE_ENV=production during the build step.
production=false
