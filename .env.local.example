# ============================================================================
# Divini Partners — UNIFIED LOCAL STACK env contract
# ----------------------------------------------------------------------------
# Procure now runs as a Vite SPA + an Express/Postgres backend (server/), on the
# SAME self-hosted stack as the sibling app divinipartner:
#   * Auth    = Authentik (OIDC, Authorization Code + PKCE)
#   * DB      = plain Postgres (the AI Builder OS local PG at localhost:5433)
#   * Storage = local disk (FILE_STORAGE_DIR)
#
# Copy to `.env.local` and fill in. Build-time VITE_* vars are inlined into the
# SPA bundle; the rest are read by the backend at runtime.
# ============================================================================

# --- Database (plain local Postgres; no SSL needed on localhost) ------------
# Create the DB + apply db/schema.sql first (see db/schema.sql header / CHANGES.md).
DATABASE_URL=postgres://aibos:CHANGE_ME@localhost:5433/divini_partners

# --- Authentik OIDC — BACKEND token verification (runtime) ------------------
# Issuer/JWKS/audience for the Authentik "divini-partners" application+provider.
OIDC_ISSUER=https://auth.divinipartners.com/application/o/divini-partners/
OIDC_JWKS_URL=https://auth.divinipartners.com/application/o/divini-partners/jwks/
OIDC_CLIENT_ID=replace-with-authentik-client-id
# Optional — only if the backend ever performs the OIDC code exchange itself.
# Pure SPA PKCE + backend JWT validation does NOT need this.
OIDC_CLIENT_SECRET=

# --- Authentik OIDC — FRONTEND (build-time, inlined by Vite) ----------------
VITE_OIDC_ISSUER=https://auth.divinipartners.com/application/o/divini-partners/
VITE_OIDC_CLIENT_ID=replace-with-authentik-client-id
# Defaults to <origin><BASE_PATH>/auth/callback when omitted.
VITE_OIDC_REDIRECT_URI=http://localhost:3011/auth/callback
# Optional: dedicated Authentik enrollment / recovery flow URLs for the Login page
# "Create an account" and "Forgot password" actions. When unset, both fall back to
# the hosted sign-in (which links to enrollment/recovery when those flows are bound),
# so nothing 404s. Set to the confirmed flow URLs to send users straight there.
# VITE_OIDC_ENROLLMENT_URL=https://auth.divinipartners.com/if/flow/default-enrollment-flow/
# VITE_OIDC_RECOVERY_URL=https://auth.divinipartners.com/if/flow/default-recovery-flow/

# --- Admin gate -------------------------------------------------------------
# Comma-separated allowlist matched against the verified Authentik email claim.
# Drives backend requireAdmin (feature-flag writes) + the SPA admin UI.
ADMIN_ALLOWED_EMAILS=adagentpc@gmail.com

# --- File storage (local disk; replaces Supabase Storage) -------------------
# Uploads land under <FILE_STORAGE_DIR>/<companyId>/<packageId|buildingId>/...
FILE_STORAGE_DIR=/root/partners-files
# Secret used to sign short-lived (1h) download URLs (HMAC). Set a strong value.
DOWNLOAD_URL_SECRET=replace-with-a-long-random-string

# --- HTTP / serving ---------------------------------------------------------
PORT=3011
# Canonical https origin (no trailing slash). Used for CORS allowlist.
PUBLIC_APP_URL=http://localhost:3011
# Optional CORS allowlist (in addition to PUBLIC_APP_URL). Comma-separated.
# ALLOWED_ORIGINS=
# Sub-path the SPA is served under (default "/"). Must match VITE base at build.
BASE_PATH=/

# --- Email (transactional + claim outreach) --------------------------------
# Provider: "resend" (hosted) or "postal" (self-hosted). Empty = email disabled
# (every send is logged and skipped, nothing transmitted).
EMAIL_PROVIDER=resend
# Secret. Set the REAL key only on the server, never commit it here.
EMAIL_API_KEY=re_YOUR_RESEND_API_KEY
# Verified sender. The domain must be verified in Resend (DKIM/SPF in DNS).
EMAIL_FROM=Divini Partners <partners@divinipartners.com>
# Only for EMAIL_PROVIDER=postal:
# POSTAL_API_URL=https://postal.yourdomain.com

# ---- Venue revenue share (1% of gross, carved out of the platform fee) ----
# Fraction of GROSS each on-platform transaction pays the hosting venue.
VENUE_REVENUE_SHARE_RATE=0.01
# Max fraction of the platform fee the venue share may consume (0.5 => Premier
# tier fee splits 50/50 between platform and venue; richer tiers unaffected).
VENUE_SHARE_MAX_FEE_FRACTION=0.5
